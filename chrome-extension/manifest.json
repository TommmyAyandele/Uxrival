{
  "manifest_version": 3,
  "name": "UX Rival",
  "version": "1.0.0",
  "description": "Instant AI competitive UX analysis for any product.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://uxrival.xyz/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
