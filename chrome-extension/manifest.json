{
  "manifest_version": 3,
  "name": "UX Rival",
  "version": "1.0.1",
  "description": "Instant AI competitive UX analysis for any product.",
  "permissions": ["storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_title": "Open UX Rival",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Alt+Shift+U",
        "mac": "Alt+Shift+U"
      },
      "description": "Toggle UX Rival panel"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
